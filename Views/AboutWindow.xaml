<Window x:Class="SystemMonitorApp.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About SystemFlow Pro"
        Height="560" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="/app.ico"
        Background="#0D0E13"
        FontFamily="Segoe UI Variable"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <!-- Teal dark-mode palette -->
        <SolidColorBrush x:Key="AccentBrush" Color="#00E5C7"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#33EDD5"/>
        <SolidColorBrush x:Key="CardBrush" Color="#191B23"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#242731"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#A8B2C0"/>
        <SolidColorBrush x:Key="WindowBgBrush" Color="#0D0E13"/>

        <!-- Section heading -->
        <Style x:Key="SectionHeading" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Body text -->
        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="18"/>
        </Style>

        <!-- Hyperlink style: accent color, underline on hover only -->
        <Style TargetType="Hyperlink">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="TextDecorations" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}"/>
                    <Setter Property="TextDecorations" Value="Underline"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- OK button -->
        <Style x:Key="OkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#0D0E13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="28,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="28,24,28,16">
            <StackPanel>

                <!-- Header: product name + version -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <!-- Accent badge (CSS-style shape, no emoji) -->
                    <Border Width="40" Height="40"
                            CornerRadius="10"
                            Background="{StaticResource AccentBrush}"
                            VerticalAlignment="Center">
                        <TextBlock Text="SF"
                                   FontFamily="Segoe UI Variable Display"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#0D0E13"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="SystemFlow Pro"
                                   FontFamily="Segoe UI Variable Display"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   AutomationProperties.Name="SystemFlow Pro produktnamn"/>
                        <TextBlock x:Name="VersionText"
                                   Text="v1.1.0"
                                   FontSize="12"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,2,0,0"
                                   AutomationProperties.Name="Version number"/>
                    </StackPanel>
                </StackPanel>

                <!-- Build date -->
                <TextBlock x:Name="BuildDateText"
                           Text="Built: 2026-04-22"
                           Style="{StaticResource BodyText}"
                           Margin="0,10,0,16"
                           AutomationProperties.Name="Build date"/>

                <!-- Description -->
                <Border Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16,14"
                        Margin="0,0,0,16">
                    <TextBlock Style="{StaticResource BodyText}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Lightweight and fast system monitoring for Windows. Displays CPU, GPU, memory, temperatures and fans in real time."/>
                </Border>

                <!-- Links -->
                <TextBlock Text="Links" Style="{StaticResource SectionHeading}"/>
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,4">
                        <Run Text="GitHub: "/>
                        <Hyperlink NavigateUri="https://github.com/screamm/SystemFlow_Pro"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   AutomationProperties.Name="Open GitHub repository">
                            github.com/screamm/SystemFlow_Pro
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Style="{StaticResource BodyText}">
                        <Run Text="Report a bug: "/>
                        <Hyperlink NavigateUri="https://github.com/screamm/SystemFlow_Pro/issues"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   AutomationProperties.Name="Report a bug on GitHub">
                            github.com/screamm/SystemFlow_Pro/issues
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

                <!-- Third-party libraries -->
                <TextBlock Text="Third-party libraries" Style="{StaticResource SectionHeading}"/>
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,4">
                        <Run Text="LibreHardwareMonitor 0.9.4 — "/>
                        <Hyperlink NavigateUri="https://github.com/LibreHardwareMonitor/LibreHardwareMonitor/blob/master/LICENSE"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   AutomationProperties.Name="LibreHardwareMonitor MPL 2.0-licens">
                            MPL 2.0
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,4">
                        <Run Text=".NET 9 Runtime — "/>
                        <Hyperlink NavigateUri="https://github.com/dotnet/runtime/blob/main/LICENSE.TXT"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   AutomationProperties.Name=".NET 9 MIT-licens">
                            MIT
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Style="{StaticResource BodyText}"
                               Text="Segoe Fluent Icons — included in Windows"/>
                </StackPanel>

                <!-- License -->
                <TextBlock Text="License" Style="{StaticResource SectionHeading}"/>
                <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,8">
                    <Run Text="This program is open source, MIT license. "/>
                    <Hyperlink NavigateUri="https://github.com/screamm/SystemFlow_Pro/blob/main/LICENSE"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               AutomationProperties.Name="Read the full MIT license">
                        Read the license
                    </Hyperlink>
                </TextBlock>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer with OK button -->
        <Border Grid.Row="1"
                Background="{StaticResource WindowBgBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="28,14">
            <Button x:Name="OkButton"
                    Content="OK"
                    Style="{StaticResource OkButtonStyle}"
                    HorizontalAlignment="Right"
                    IsDefault="True"
                    TabIndex="1"
                    Click="OkButton_Click"
                    AutomationProperties.Name="Close About dialog"/>
        </Border>
    </Grid>
</Window>
