<Application x:Class="SystemMonitorApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <!--
            Application-wide resources.
            NOTE: The full color palette and styles are defined in MainWindow.xaml to keep
            everything in one place. Dialogs (SettingsWindow, AboutWindow) define their
            own local brushes with matching values. This avoids resource-lookup collisions
            that existed when App.xaml had a separate, conflicting palette.

            Only truly global styles that all windows share belong here.
        -->

        <!-- Accessible focus visual — must be global so all windows/dialogs can use it -->
        <Style x:Key="AccessibleFocusVisual">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle StrokeThickness="2"
                                   Stroke="#00E5C7"
                                   StrokeDashArray="1 2"
                                   Margin="-2"
                                   SnapsToDevicePixels="True"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
