<Window x:Class="SystemMonitorApp.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SystemFlow Pro Loading..." Height="400" Width="600"
        Icon="app.ico"
        WindowStartupLocation="CenterScreen"
        Background="#FF0D0E13"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Topmost="True">

    <Window.Resources>
        <!-- Color Brushes -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#0D0E13"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#00E5C7"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="CardBrush" Color="#191B23"/>

        <!-- Loading Animation -->
        <Storyboard x:Key="LoadingAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" 
                           From="0" To="360" Duration="0:0:2"/>
        </Storyboard>

        <!-- Fade In Animation -->
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
        </Storyboard>
    </Window.Resources>

    <Border Background="{StaticResource CardBrush}" CornerRadius="20" BorderThickness="2">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.6">
                <GradientStop Color="#00E5C7" Offset="0"/>
                <GradientStop Color="#7C3AED" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#00E5C7" BlurRadius="30" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="60"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Logo and Brand -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="80" Height="80" Background="{StaticResource AccentBrush}" CornerRadius="16" Margin="0,0,0,20">
                    <TextBlock Text="S" FontFamily="Segoe UI Variable Display" FontSize="48" FontWeight="Bold" 
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="SystemFlow" FontFamily="Segoe UI Variable Display" FontSize="32" FontWeight="Bold" 
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="PRO" FontFamily="Segoe UI Variable" FontSize="18" FontWeight="Bold" 
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <TextBlock x:Name="VersionText" Text="v1.1.0" FontFamily="Segoe UI Variable" FontSize="14" FontWeight="Medium"
                               Foreground="#94A3B8" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Loading Indicator with Fixed Height -->
            <Grid Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Ellipse Width="40" Height="40" Stroke="{StaticResource AccentBrush}" StrokeThickness="4" 
                         StrokeDashArray="8,4" x:Name="LoadingSpinner" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse.RenderTransform>
                        <RotateTransform CenterX="20" CenterY="20"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Ellipse.Loaded">
                            <BeginStoryboard Storyboard="{StaticResource LoadingAnimation}"/>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
            </Grid>

            <!-- Loading Text with Proper Spacing -->
            <StackPanel Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0">
                <TextBlock x:Name="LoadingText" Text="Initializing hardware monitor..."
                           FontFamily="Segoe UI Variable" FontSize="16" FontWeight="Medium"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Loading sensors and system configuration..."
                           FontFamily="Segoe UI Variable" FontSize="12" FontWeight="Normal"
                           Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeInAnimation}"/>
        </EventTrigger>
    </Window.Triggers>
</Window>